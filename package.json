{
  "name": "context-vault",
  "version": "0.2.0",
  "description": "Context Vault — Privacy-first, read-only AI document bridge",
  "author": "Context Vault <noreply@example.com>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/e2e.js",
    "build": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.context-vault.app",
    "productName": "Context Vault",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "dir"
      ]
    },
    "dmg": {
      "title": "Context Vault",
      "iconSize": 80
    },
    "files": [
      "main.js",
      "signaling.js",
      "mcp-bridge.js",
      "mcp-bridge-testable.js",
      "privacy-dashboard.html",
      "dashboard-preload.js",
      "assets/**/*"
    ]
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "ws": "^8.20.0",
    "@roamhq/wrtc": "^0.10.0",
    "@e965/xlsx": "^0.20.3"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.9.10"
  }
}
